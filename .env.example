# .env
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to git.

# ── Option A: Use Anthropic directly ──────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
MODEL_ID=claude-sonnet-4-20250514

# ── Option B: Use a non-Anthropic model via LiteLLM proxy ─────────────────
# Start the proxy first: litellm --config litellm_config.yaml --port 4000
# Then set these instead of ANTHROPIC_API_KEY above:
#
# ANTHROPIC_BASE_URL=http://localhost:4000
# ANTHROPIC_API_KEY=dummy-key-litellm-ignores-this
# MODEL_ID=my-nebius-model

# ── Option B provider keys (used by litellm_config.yaml) ──────────────────
# NEBIUS_API_KEY=...
# OPENAI_API_KEY=...
# GROQ_API_KEY=...

# ── s22: Redis mailbox (optional) ─────────────────────────────────────────
# Only needed if running s22_production_mailbox.py
# Default: redis://localhost:6379
# REDIS_URL=redis://localhost:6379
